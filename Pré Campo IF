<script>
const SECTIONS = ['s0','s1','s2','s3','s4','s5','s6','s7'];
const SECTION_NAMES = {
  s0:'Identificacao do Projeto', s1:'Habilitacoes e Cadastros',
  s2:'Autorizacoes de Acesso',   s3:'Documentacao Tecnica',
  s4:'Equipamentos de Medicao',  s5:'Materiais de Marcacao',
  s6:'Equipe e Seguranca',       s7:'Verificacao Final'
};
let estadoAtual = 'ambos';

function setEstado(est) {
  estadoAtual = est;
  ['ambos','AP','PA'].forEach(e => document.getElementById('btn-'+e).classList.toggle('active', e===est));
  document.querySelectorAll('.item[data-estado]').forEach(el => {
    const de = el.getAttribute('data-estado');
    el.classList.toggle('visible', est==='ambos' || de===est);
  });
  document.getElementById('footerEstado').textContent = est==='ambos' ? 'AP + PA' : est;
  updateProgress(); saveState();
}

function toggle(el) { el.classList.toggle('checked'); updateProgress(); saveState(); }
function toggleSection(id) { document.getElementById(id).classList.toggle('collapsed'); }

function getVisible() {
  return Array.from(document.querySelectorAll('.item')).filter(el => {
    const de = el.getAttribute('data-estado');
    return !de || estadoAtual==='ambos' || de===estadoAtual;
  });
}

function updateProgress() {
  const all  = getVisible();
  const done = all.filter(el => el.classList.contains('checked'));
  const pct  = all.length ? Math.round((done.length/all.length)*100) : 0;
  document.getElementById('progFill').style.width = pct+'%';
  document.getElementById('progPct').textContent  = pct+'%';
  document.getElementById('footerCount').textContent = done.length;
  document.getElementById('footerTotal').textContent  = all.length;
  SECTIONS.forEach(sid => {
    const sec = document.getElementById(sid); if (!sec) return;
    const items = Array.from(sec.querySelectorAll('.item')).filter(el => {
      const de = el.getAttribute('data-estado');
      return !de || estadoAtual==='ambos' || de===estadoAtual;
    });
    const chk = items.filter(el => el.classList.contains('checked'));
    const b = document.getElementById('badge-'+sid);
    if (b) { b.textContent = chk.length+'/'+items.length; b.classList.toggle('done', items.length>0 && chk.length===items.length); }
  });
  document.getElementById('conclusionBanner').classList.toggle('show', pct===100 && all.length>0);
}

function resetAll() {
  if (!confirm('Limpar todos os itens marcados?')) return;
  document.querySelectorAll('.item.checked').forEach(el => el.classList.remove('checked'));
  updateProgress(); localStorage.removeItem('chklist_if_v3');
}

function saveState() {
  const checks = Array.from(document.querySelectorAll('.item')).map(el => el.classList.contains('checked'));
  localStorage.setItem('chklist_if_v3', JSON.stringify({checks, estado:estadoAtual}));
}

function loadState() {
  const raw = localStorage.getItem('chklist_if_v3'); if (!raw) return;
  try {
    const {checks, estado} = JSON.parse(raw);
    if (estado) setEstado(estado);
    document.querySelectorAll('.item').forEach((el,i) => { if (checks[i]) el.classList.add('checked'); });
  } catch(e){}
  updateProgress();
}

function exportTxt() {
  let out = 'CHECKLIST PRE-CAMPO – INVENTARIO FLORESTAL RDR\n';
  out += 'Estado: '+(estadoAtual==='ambos'?'AP + PA':estadoAtual)+'\n';
  out += 'Gerado em: '+new Date().toLocaleString('pt-BR')+'\n';
  out += '='.repeat(58)+'\n\n';
  SECTIONS.forEach(sid => {
    const sec = document.getElementById(sid); if (!sec) return;
    const items = Array.from(sec.querySelectorAll('.item')).filter(el => {
      const de = el.getAttribute('data-estado');
      return !de || estadoAtual==='ambos' || de===estadoAtual;
    });
    const chk = items.filter(el => el.classList.contains('checked'));
    out += '[ '+SECTION_NAMES[sid]+' ] – '+chk.length+'/'+items.length+'\n';
    items.forEach(el => {
      const txt = el.querySelector('.item-text').innerText.replace(/\n/g,' ').replace(/\s+/g,' ').trim();
      out += '  '+(el.classList.contains('checked')?'[X]':'[ }')+' '+txt+'\n';
    });
    out += '\n';
  });
  const a = document.createElement('a');
  a.href = URL.createObjectURL(new Blob([out],{type:'text/plain;charset=utf-8'}));
  a.download = 'Checklist_PreCampo_IF_'+new Date().toISOString().slice(0,10)+'.txt';
  a.click();
}

setEstado('ambos');
loadState();
</script>
</body>
</html>
